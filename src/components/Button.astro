---
import { Icon } from "astro-icon/components";

export interface Props {
  text: string;
  class?: string;
  href?: string;
  icon?: string;
  variant?: "dark" | "white" | "lime";
  filled?: boolean;
}

const {
  text,
  class: className = "",
  href,
  icon,
  variant = "dark",
  filled = false,
} = Astro.props;

const baseClasses =
  "w-fit px-[54px] py-[9px] rounded-[50px] border font-semibold text-[14px] leading-[22px] tracking-normal text-center hover:opacity-80 transition-opacity flex items-center justify-center gap-2 cursor-pointer";

const variantClasses = filled
  ? variant === "white"
    ? "bg-white text-brand-dark border-white"
    : variant === "lime"
      ? "bg-brand-lime text-brand-dark border-brand-lime"
      : "bg-brand-dark text-white border-brand-dark"
  : variant === "white"
    ? "border-white text-white"
    : variant === "lime"
      ? "border-brand-lime text-brand-lime"
      : "border-brand-dark text-brand-dark";
---

{href ? (
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class={`${baseClasses} ${variantClasses} ${className}`}
  >
    {text}
    {icon && <Icon name={icon} width="16" height="16" />}
  </a>
) : (
  <button class={`${baseClasses} ${variantClasses} ${className}`}>
    {text}
    {icon && <Icon name={icon} width="16" height="16" />}
  </button>
)}
