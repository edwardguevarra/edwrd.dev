---
import Button from "./Button.astro";
import { getNavigationItems } from "../config/navigation";

// Check if we're on a blog page
const isBlogPage = Astro.url.pathname.startsWith("/blog");
const isHomePage = Astro.url.pathname === "/";

// Get navigation items with computed hrefs
const navItems = getNavigationItems(isHomePage);
---

<header class="bg-brand-dark py-6 lg:py-12">
  <div class="container">
    <!-- Mobile Header -->
    <div class="flex items-center justify-between lg:hidden">
      <!-- Logo -->
      <a
        href="/"
        class="text-brand-lime font-bold text-xl hover:opacity-80 transition-opacity"
      >
        edwrd
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="text-white p-2"
        aria-label="Toggle menu"
      >
        <svg
          id="menu-icon"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Desktop Header -->
    <div class="hidden lg:grid lg:grid-cols-3 items-center">
      <!-- Logo -->
      <a
        href="/"
        class="text-brand-lime font-bold text-xl hover:opacity-80 transition-opacity"
      >
        edwrd
      </a>

      <!-- Navigation Links -->
      <nav class="flex items-center justify-center gap-[100px]">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              data-section={item.section}
              {...(item.section === "blog" && !isHomePage
                ? { "data-astro-prefetch": "true" }
                : {})}
              class={`nav-link ${item.section === "blog" && isBlogPage ? "text-brand-lime" : "text-white"} hover:opacity-80 transition-all font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer`}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- CTA Button -->
      <div class="flex justify-end">
        <Button
          text="Let's Talk"
          variant="white"
          filled={true}
          class="ml-auto"
        />
      </div>
    </div>

    <!-- Mobile Menu Backdrop -->
    <div
      id="mobile-menu-backdrop"
      class="mobile-menu-backdrop fixed inset-0 bg-black/50 z-40 lg:hidden hidden"
    >
    </div>

    <!-- Mobile Menu -->
    <nav
      id="mobile-menu"
      class="mobile-menu lg:hidden mt-6 pb-4 border-t border-white/10 relative z-50 hidden"
    >
      <div class="flex flex-col gap-4 pt-4">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              data-section={item.section}
              class={`nav-link ${item.section === "blog" && isBlogPage ? "text-brand-lime" : "text-white"} hover:opacity-80 transition-all py-2 cursor-pointer`}
            >
              {item.label}
            </a>
          ))
        }
        <div id="mobile-menu-button-wrapper">
          <Button text="Let's Talk" variant="white" filled={true} />
        </div>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuBackdrop = document.getElementById("mobile-menu-backdrop");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  const openMobileMenu = () => {
    mobileMenuBackdrop?.classList.remove("hidden");
    mobileMenu?.classList.remove("hidden");
    menuIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
    // Trigger animation by removing hidden class first, then adding open class
    requestAnimationFrame(() => {
      mobileMenuBackdrop?.classList.add("mobile-menu-backdrop-open");
      mobileMenu?.classList.add("mobile-menu-open");
    });
    // Prevent body scroll when menu is open
    document.body.style.overflow = "hidden";
  };

  const closeMobileMenu = () => {
    mobileMenuBackdrop?.classList.remove("mobile-menu-backdrop-open");
    mobileMenu?.classList.remove("mobile-menu-open");
    // Wait for animation to complete before hiding
    setTimeout(() => {
      mobileMenuBackdrop?.classList.add("hidden");
      mobileMenu?.classList.add("hidden");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      document.body.style.overflow = "";
    }, 300);
  };

  mobileMenuButton?.addEventListener("click", () => {
    const isHidden = mobileMenu?.classList.contains("hidden");

    if (isHidden) {
      openMobileMenu();
    } else {
      closeMobileMenu();
    }
  });

  // Close mobile menu when clicking backdrop
  mobileMenuBackdrop?.addEventListener("click", closeMobileMenu);

  // Close mobile menu when clicking navigation links
  const mobileNavLinks = mobileMenu?.querySelectorAll(".nav-link");
  mobileNavLinks?.forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  // Close mobile menu when clicking "Let's Talk" button
  const mobileMenuButtonWrapper = document.getElementById(
    "mobile-menu-button-wrapper"
  );
  const mobileTalkButton = mobileMenuButtonWrapper?.querySelector("button");
  mobileTalkButton?.addEventListener("click", closeMobileMenu);

  // Active navigation state using Intersection Observer
  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll(".nav-link");

  // Check if we're on a blog page
  const isBlogPage = window.location.pathname.startsWith("/blog");

  // Function to update active navigation link
  const updateActiveNav = (activeSectionId) => {
    navLinks.forEach((link) => {
      const linkSection = link.getAttribute("data-section");
      if (linkSection === activeSectionId) {
        link.classList.add("text-brand-lime");
        link.classList.remove("text-white");
      } else {
        // Don't override blog link styling if we're on blog page
        if (linkSection === "blog" && isBlogPage) {
          return;
        }
        link.classList.remove("text-brand-lime");
        link.classList.add("text-white");
      }
    });
  };

  // If on blog page, highlight blog link
  if (isBlogPage) {
    navLinks.forEach((link) => {
      const linkSection = link.getAttribute("data-section");
      if (linkSection === "blog") {
        link.classList.add("text-brand-lime");
        link.classList.remove("text-white");
      } else {
        link.classList.remove("text-brand-lime");
        link.classList.add("text-white");
      }
    });
  }

  // Intersection Observer configuration
  const observerOptions = {
    root: null,
    rootMargin: "-20% 0px -60% 0px", // Trigger when section is in upper portion of viewport
    threshold: 0,
  };

  // Track which sections are currently intersecting
  const intersectingSections = new Map();

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        intersectingSections.set(entry.target, entry.intersectionRatio);
      } else {
        intersectingSections.delete(entry.target);
      }
    });

    // Determine the most visible section
    if (intersectingSections.size > 0) {
      let maxRatio = 0;
      let activeSection = null;

      intersectingSections.forEach((ratio, section) => {
        if (ratio > maxRatio) {
          maxRatio = ratio;
          activeSection = section;
        }
      });

      if (activeSection && activeSection.id) {
        const sectionId = activeSection.id;
        updateActiveNav(sectionId);
      }
    } else {
      // If no sections are intersecting (e.g., at top of page), check scroll position
      const scrollPosition = window.scrollY;
      if (scrollPosition < 100) {
        // Near top of page, default to first section (about)
        updateActiveNav("about");
      }
    }
  }, observerOptions);

  // Initial state: check which section should be active on page load
  const checkInitialActiveSection = () => {
    // Don't run intersection observer logic on blog pages
    if (isBlogPage) {
      return;
    }

    const scrollPosition = window.scrollY;
    if (scrollPosition < 100) {
      updateActiveNav("about");
    } else {
      // Find the first section that's in view
      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= window.innerHeight * 0.3 && rect.bottom >= 0) {
          updateActiveNav(section.id);
        }
      });
    }
  };

  // Set initial active state (only on homepage)
  if (!isBlogPage) {
    checkInitialActiveSection();

    // Observe all sections (only on homepage)
    sections.forEach((section) => {
      if (section.id) {
        observer.observe(section);
      }
    });
  }
</script>
