---
import Button from "./Button.astro";
import MobileMenu from "./MobileMenu.astro";
import NavLink from "./NavLink.astro";
import { getNavigationItems } from "../config/navigation";
import { Icon } from "astro-icon/components";

// Check if we're on a blog page
const isBlogPage = Astro.url.pathname.startsWith("/blog");
const isHomePage = Astro.url.pathname === "/";

// Get navigation items with computed hrefs
const navItems = getNavigationItems(isHomePage);
---

<header class="bg-brand-dark py-6 lg:py-12">
  <div class="container">
    <!-- Mobile Header -->
    <div class="flex items-center justify-between lg:hidden">
      <!-- Logo -->
      <a
        href="/"
        class="text-brand-lime font-bold text-xl hover:opacity-80 transition-opacity"
      >
        edwrd
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="text-white p-2"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon id="menu-icon" name="heroicons:bars-3" class="w-6 h-6" />
        <Icon id="close-icon" name="heroicons:x-mark" class="w-6 h-6 hidden" />
      </button>
    </div>

    <!-- Desktop Header -->
    <div class="hidden lg:grid lg:grid-cols-3 items-center">
      <!-- Logo -->
      <a
        href="/"
        class="text-brand-lime font-bold text-xl hover:opacity-80 transition-opacity"
      >
        edwrd
      </a>

      <!-- Navigation Links -->
      <nav class="flex items-center justify-center gap-[100px] relative z-10" role="navigation" aria-label="Main navigation">
        {
          navItems.map((item) => (
            <NavLink
              href={item.href}
              label={item.label}
              section={item.section}
              isActive={item.section === "blog" && isBlogPage}
              prefetch={item.section === "blog" && !isHomePage}
            />
          ))
        }
      </nav>

      <!-- CTA Button -->
      <div class="flex justify-end relative z-0">
        <Button
          text="Let's Talk"
          variant="white"
          filled={true}
          class="ml-auto"
        />
      </div>
    </div>

    <!-- Mobile Menu Component -->
    <MobileMenu navItems={navItems} isBlogPage={isBlogPage} />
  </div>
</header>

<script>
  // Wait for DOM to be ready
  document.addEventListener('DOMContentLoaded', () => {
    // Load navigation services dynamically
    Promise.all([
      import('../services/navigation-manager.js'),
      import('../services/mobile-menu-controller.js')
    ]).then(([{ NavigationManager }, { MobileMenuController }]) => {
      // Initialize navigation manager for active section highlighting
      const navigationManager = new NavigationManager();
      navigationManager.initialize();

      // Initialize mobile menu controller for mobile menu functionality
      const mobileMenuController = new MobileMenuController();

      // Cleanup on page unload
      window.addEventListener('beforeunload', () => {
        navigationManager.destroy();
        mobileMenuController.destroy();
      });
    }).catch(error => {
      console.error('Failed to load navigation services:', error);
    });
  });
</script>
