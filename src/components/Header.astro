---

---

<header class="bg-brand-dark py-6 lg:py-12">
  <div class="container">
    <!-- Mobile Header -->
    <div class="flex items-center justify-between lg:hidden">
      <!-- Logo -->
      <div class="text-brand-lime font-bold text-xl">edwrd</div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="text-white p-2"
        aria-label="Toggle menu"
      >
        <svg
          id="menu-icon"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Desktop Header -->
    <div class="hidden lg:grid lg:grid-cols-3 items-center">
      <!-- Logo -->
      <div class="text-brand-lime font-bold text-xl">edwrd</div>

      <!-- Navigation Links -->
      <nav class="flex items-center justify-center gap-[100px]">
        <a href="#about" class="text-white hover:opacity-80 transition-opacity"
          >About</a
        >
        <a href="#works" class="text-white hover:opacity-80 transition-opacity"
          >Works</a
        >
        <a
          href="#contact"
          class="text-white hover:opacity-80 transition-opacity">Contact</a
        >
        <a href="#blog" class="text-white hover:opacity-80 transition-opacity"
          >Blog</a
        >
      </nav>

      <!-- CTA Button -->
      <div class="flex justify-end">
        <button
          class="bg-white text-brand-dark px-6 py-2 rounded-full font-medium hover:opacity-90 transition-opacity w-[170px]"
        >
          Let's Talk
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <nav
      id="mobile-menu"
      class="hidden lg:hidden mt-6 pb-4 border-t border-white/10"
    >
      <div class="flex flex-col gap-4 pt-4">
        <a
          href="#about"
          class="text-white hover:opacity-80 transition-opacity py-2">About</a
        >
        <a
          href="#works"
          class="text-white hover:opacity-80 transition-opacity py-2">Works</a
        >
        <a
          href="#contact"
          class="text-white hover:opacity-80 transition-opacity py-2">Contact</a
        >
        <a
          href="#blog"
          class="text-white hover:opacity-80 transition-opacity py-2">Blog</a
        >
        <button
          class="bg-white text-brand-dark px-6 py-2 rounded-full font-medium hover:opacity-90 transition-opacity w-full mt-2"
        >
          Let's Talk
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  mobileMenuButton?.addEventListener("click", () => {
    const isHidden = mobileMenu?.classList.contains("hidden");

    if (isHidden) {
      mobileMenu?.classList.remove("hidden");
      menuIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
    } else {
      mobileMenu?.classList.add("hidden");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    }
  });
</script>
