---
import OutlineButton from "./buttons/OutlineButton.astro";
import { Image } from "astro:assets";
import contactIcon from "../assets/contact.png";

const contactLinks = [
  {
    text: "edwardguevarra2003@gmail.com",
    href: "mailto:edwardguevarra2003@gmail.com",
    icon: undefined,
    target: undefined,
    delay: 200,
  },
  {
    text: "LinkedIn",
    href: "https://linkedin.com/in/edwardguevarra",
    icon: "heroicons:arrow-top-right-on-square",
    target: "_blank",
    delay: 300,
  },
  {
    text: "GitHub",
    href: "https://github.com/shizokura",
    icon: "heroicons:arrow-top-right-on-square",
    target: "_blank",
    delay: 400,
  },
  {
    text: "Discord",
    href: "https://discord.com/users/204564936729427968",
    icon: "heroicons:arrow-top-right-on-square",
    target: "_blank",
    delay: 500,
  },
];
---

<section id="contact" class="bg-brand-dark pt-16 pb-18">
  <div class="relative container pt-0 xl:pt-20">
    <div
      class="flex flex-col flex-wrap items-center justify-between xl:flex-row xl:items-start"
    >
      <div
        data-animate
        class="text-brand-accent pb-8 text-center text-6xl font-black lg:pb-0 xl:text-left"
      >
        <div>Contact Me,</div>
        <div>Let's Talk</div>
      </div>
      <div class="flex flex-col gap-20 pt-8 xl:pt-0">
        <div
          data-animate
          class="animate-delay-100 max-w-xl text-center text-sm text-white xl:text-right"
        >
          <div>
            Got a project in mind? Need a developer to bring your ideas to life
            or transform them into real solutions? Looking to collaborate on
            something exciting?
          </div>
          <div class="mt-3">
            Let's connect! Shoot me a message and let's make it happen.
          </div>
        </div>
        <div class="flex flex-col gap-6">
          {
            contactLinks.map((link) => (
              <div data-animate class={`animate-delay-${link.delay}`}>
                <OutlineButton
                  text={link.text}
                  href={link.href}
                  icon={link.icon}
                  target={link.target}
                  color="white"
                  class="mr-auto ml-auto md:mr-0"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
    <div
      data-animate
      class="animate-delay-300 absolute -bottom-55 left-0 hidden md:block"
    >
      <Image src={contactIcon} alt="Contact" width={437} height={445} />
    </div>
  </div>
</section>
