---
import { Image } from "astro:assets";
import aboutImage1 from "../assets/about-1.png";
import aboutImage2 from "../assets/about-2.png";
import OutlineButton from "./buttons/OutlineButton.astro";
import Marquee from "./Marquee.astro";

const hobbies = [
  "I play games",
  "Motorcycle rides",
  "I learn piano",
  "Watching anime",
];

const experiences = [
  {
    period: "2023 - present",
    title: "Full-stack Developer",
    company: "Bapplware Technologies, Inc",
  },
  {
    period: "2021 - 2023",
    title: "Full-stack Developer",
    company: "GEER IT Solutions",
  },
  {
    period: "2020 - 2021",
    title: "Web Developer",
    company: "My Solid Technologies & Devices Corp.",
  },
  {
    period: "2016 - 2020",
    title: "Web Developer",
    company: "Digima Web Solutions",
  },
];
---

<section id="about" class="bg-brand-accent py-8 sm:py-10 md:py-12">
  <!-- Marquee Text -->
  <Marquee />

  <div class="container">
    <!-- Two Column Grid -->
    <div class="flex flex-col items-start gap-8 md:gap-12 lg:flex-row">
      <!-- Left Column - Images -->
      <div class="relative flex w-full shrink-0 flex-col gap-6 lg:w-[425px]">
        <!-- Section Title -->
        <h2
          data-animate
          class="text-brand-dark mb-4 text-center text-4xl font-black sm:mb-6 sm:text-5xl md:mb-8 lg:text-right lg:text-6xl"
        >
          <div>About</div>
          <div>Me</div>
        </h2>
        <div
          class="flex flex-col items-center gap-4 sm:flex-row sm:items-start sm:justify-center sm:gap-6 lg:block lg:gap-0"
        >
          <div
            data-animate
            class="aspect-[237/414] w-full max-w-[280px] overflow-hidden sm:w-1/2 sm:max-w-none lg:ml-auto lg:w-auto lg:max-w-[237px]"
          >
            <Image
              src={aboutImage1}
              alt="Edward Guevarra"
              width={237}
              height={414}
              loading="eager"
              class="h-full w-full object-cover"
            />
          </div>
          <div
            data-animate
            class="animate-delay-200 aspect-[237/414] w-full max-w-[280px] overflow-hidden sm:w-1/2 sm:max-w-none lg:-mt-50 lg:w-[237px] lg:max-w-none"
          >
            <Image
              src={aboutImage2}
              alt="Edward Guevarra"
              width={237}
              height={414}
              loading="lazy"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Combined Column - Biography, Experience Timeline, Hobbies, and Job Roles -->
      <div class="flex w-full flex-col gap-8 pt-0 md:gap-12 lg:pt-47">
        <!-- Two Column Grid for Biography and Hobbies -->
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
          <h2
            class="text-brand-dark order-1 block text-center text-4xl font-black sm:text-5xl md:order-none md:hidden lg:text-right lg:text-6xl"
          >
            Bio
          </h2>

          <!-- Biography Column -->
          <div
            data-animate
            class="text-brand-dark animate-delay-100 order-2 text-sm leading-relaxed md:order-none md:text-base"
          >
            <p>
              Hey there! I'm Edward Guevarra, a senior full-stack developer
              based in Bulacan, Philippines. My journey into coding started with
              an early fascination for how things work behind the scenes. I've
              always had a passion for building, whether it's crafting elegant
              solutions or bringing ideas to life through code. Over the years,
              I've honed my skills through various projects and collaborations,
              constantly learning and adapting to new technologies and
              challenges.
            </p>
          </div>

          <!-- Hobbies Column -->
          <div data-animate class="animate-delay-200 order-3 md:order-none">
            <div class="flex flex-col gap-3 sm:gap-4 md:gap-6">
              {
                hobbies.map((hobby, index) => {
                  const delayClasses = [
                    "animate-delay-300",
                    "animate-delay-400",
                    "animate-delay-500",
                    "animate-delay-600",
                  ];
                  return (
                    <div data-animate class={delayClasses[index] || ""}>
                      <OutlineButton
                        text={hobby}
                        class="w-full md:ml-auto md:w-auto"
                        data-testid={`hobby-button-${index}`}
                      />
                    </div>
                  );
                })
              }
            </div>
          </div>
        </div>

        <h2
          class="text-brand-dark block text-center text-4xl font-black sm:text-5xl md:hidden lg:text-right lg:text-6xl"
        >
          Experiences
        </h2>

        <!-- Experience Timeline and Job Roles Paired -->
        <div class="flex flex-col gap-6 md:gap-4">
          {
            experiences.map((experience, index) => {
              const delayClasses = [
                "",
                "animate-delay-100",
                "animate-delay-200",
                "animate-delay-300",
              ];
              return (
                <div
                  data-animate
                  class={`flex flex-col items-stretch justify-between gap-3 sm:items-center md:flex-row ${delayClasses[index] || ""}`}
                >
                  <OutlineButton
                    class="w-full sm:w-auto"
                    text={experience.period}
                    data-testid={`experience-button-${index}`}
                  />
                  <div class="space-y-1 text-center md:text-right">
                    <div class="text-brand-dark text-sm font-bold md:text-base">
                      {experience.title}
                    </div>
                    <div class="text-brand-dark text-sm md:text-base">
                      {experience.company}
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>
