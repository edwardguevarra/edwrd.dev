---
import Button from "./Button.astro";
---

<section id="about" class="bg-brand-accent py-6">
  <!-- Marquee Text -->
  <div class="marquee-container overflow-hidden mb-8">
    <div class="marquee-content flex gap-8">
      <span class="marquee-text text-brand-dark whitespace-nowrap">
        print("Hello World") | console.log("Hello World"); | echo "Hello World";
        | System.out.println("Hello World"); | printf("Hello World\n"); | cout
        &lt;&lt; "Hello World" &lt;&lt; endl;
      </span>
      <span
        class="marquee-text text-brand-dark whitespace-nowrap"
        aria-hidden="true"
      >
        print("Hello World") | console.log("Hello World"); | echo "Hello World";
        | System.out.println("Hello World"); | printf("Hello World\n"); | cout
        &lt;&lt; "Hello World" &lt;&lt; endl;
      </span>
      <span
        class="marquee-text text-brand-dark whitespace-nowrap"
        aria-hidden="true"
      >
        print("Hello World") | console.log("Hello World"); | echo "Hello World";
        | System.out.println("Hello World"); | printf("Hello World\n"); | cout
        &lt;&lt; "Hello World" &lt;&lt; endl;
      </span>
      <span
        class="marquee-text text-brand-dark whitespace-nowrap"
        aria-hidden="true"
      >
        print("Hello World") | console.log("Hello World"); | echo "Hello World";
        | System.out.println("Hello World"); | printf("Hello World\n"); | cout
        &lt;&lt; "Hello World" &lt;&lt; endl;
      </span>
    </div>
  </div>

  <div class="container">
    <!-- Two Column Grid -->
    <div class="flex gap-8 md:gap-12 items-start">
      <!-- Left Column - Images -->
      <div class="flex flex-col gap-6 relative shrink-0 w-[425px]">
        <!-- Section Title -->
        <h2
          class="text-brand-dark font-black text-4xl md:text-5xl lg:text-6xl mb-8 md:mb-12 text-right"
        >
          <div>About</div>
          <div>Me</div>
        </h2>
        <div class="overflow-hidden">
          <img
            src="/images/about-1.png"
            alt="Edward Guevarra"
            class="w-[237px] h-[414px] object-cover ml-auto"
          />
        </div>
        <div class="overflow-hidden -mt-50">
          <img
            src="/images/about-2.png"
            alt="Edward Guevarra"
            class="w-[237px] h-[414px] object-cover"
          />
        </div>
      </div>

      <!-- Combined Column - Biography, Experience Timeline, Hobbies, and Job Roles -->
      <div class="flex flex-col gap-16 pt-47">
        <!-- Two Column Grid for Biography and Hobbies -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Biography Column -->
          <div class="text-brand-dark text-sm md:text-base leading-relaxed">
            <p>
              Hey there! I'm Edward Guevarra, a senior full-stack developer
              based in Bulacan, Philippines. My journey into coding started with
              an early fascination for how things work behind the scenes. I've
              always had a passion for building, whether it's crafting elegant
              solutions or bringing ideas to life through code. Over the years,
              I've honed my skills through various projects and collaborations,
              constantly learning and adapting to new technologies and
              challenges.
            </p>
          </div>

          <!-- Hobbies Column -->
          <div>
            <div class="flex flex-col gap-6">
              <Button text="I play games" position="right" />
              <Button text="Motorcycle rides" position="right" />
              <Button text="I learn piano" position="right" />
              <Button text="Watching anime" position="right" />
            </div>
          </div>
        </div>

        <!-- Experience Timeline and Job Roles Paired -->
        <div class="space-y-4">
          <!-- 2023 - present -->
          <div
            class="flex flex-col md:flex-row gap-4 items-center justify-between"
          >
            <Button text="2023 - present" />
            <div class="space-y-1 text-right">
              <div class="text-brand-dark font-bold text-sm md:text-base">
                Full-stack Developer
              </div>
              <div class="text-brand-dark text-sm md:text-base">
                Bapplware Technologies, Inc
              </div>
            </div>
          </div>

          <!-- 2021 - 2023 -->
          <div
            class="flex flex-col md:flex-row gap-4 items-center justify-between"
          >
            <Button text="2021 - 2023" />
            <div class="space-y-1 text-right">
              <div class="text-brand-dark font-bold text-sm md:text-base">
                Full-stack Developer
              </div>
              <div class="text-brand-dark text-sm md:text-base">
                GEER IT Solutions
              </div>
            </div>
          </div>

          <!-- 2020 - 2021 -->
          <div
            class="flex flex-col md:flex-row gap-4 items-center justify-between"
          >
            <Button text="2020 - 2021" />
            <div class="space-y-1 text-right">
              <div class="text-brand-dark font-bold text-sm md:text-base">
                Web Developer
              </div>
              <div class="text-brand-dark text-sm md:text-base">
                My Solid Technologies & Devices Corp.
              </div>
            </div>
          </div>

          <!-- 2016 - 2020 -->
          <div
            class="flex flex-col md:flex-row gap-4 items-center justify-between"
          >
            <Button text="2016 - 2020" />
            <div class="space-y-1 text-right">
              <div class="text-brand-dark font-bold text-sm md:text-base">
                Web Developer
              </div>
              <div class="text-brand-dark text-sm md:text-base">
                Digima Web Solutions
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-container {
    width: 100%;
  }

  .marquee-content {
    animation: marquee 20s linear infinite;
    display: flex;
    width: max-content;
  }

  .marquee-text {
    font-family: "Fira Code", monospace;
    font-weight: 600;
    font-size: 14px;
    line-height: 22px;
    letter-spacing: 0%;
    text-align: right;
    padding-right: 2rem;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .marquee-content:hover {
    animation-play-state: paused;
  }

  /* Responsive adjustments for different screen sizes */
  @media (min-width: 768px) {
    .marquee-content {
      animation-duration: 25s;
    }
  }

  @media (min-width: 1024px) {
    .marquee-content {
      animation-duration: 30s;
    }
  }

  @media (min-width: 1280px) {
    .marquee-content {
      animation-duration: 35s;
    }
  }
</style>
