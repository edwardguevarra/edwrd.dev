---

---

<section id="about" class="bg-brand-accent py-12 md:py-16 lg:py-20">
  <div class="container">
    <!-- Section Title -->
    <h2
      class="text-brand-dark font-black text-4xl md:text-5xl lg:text-6xl mb-8 md:mb-12"
    >
      About Me
    </h2>

    <!-- Three Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Left Column - Images -->
      <div class="flex flex-col gap-6">
        <div class="rounded-lg border-2 border-brand-dark overflow-hidden">
          <img
            src="https://picsum.photos/400/500?random=1"
            alt="Edward Guevarra"
            class="w-full h-auto object-cover"
          />
        </div>
        <div class="rounded-lg border-2 border-brand-dark overflow-hidden">
          <img
            src="https://picsum.photos/400/500?random=2"
            alt="Edward Guevarra"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>

      <!-- Middle Column - Biography and Experience Timeline -->
      <div class="flex flex-col gap-8">
        <!-- Biography -->
        <div class="text-brand-dark text-sm md:text-base leading-relaxed">
          <p>
            Hey there! I'm Edward Guevarra, a senior full-stack developer based
            in Bulacan, Philippines. My journey into coding started with an
            early fascination for how things work behind the scenes. I've always
            had a passion for building, whether it's crafting elegant solutions
            or bringing ideas to life through code. Over the years, I've honed
            my skills through various projects and collaborations, constantly
            learning and adapting to new technologies and challenges.
          </p>
        </div>

        <!-- Experience Timeline -->
        <div class="flex flex-wrap gap-3">
          <button
            class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
          >
            2023 - present
          </button>
          <button
            class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
          >
            2021 - 2023
          </button>
          <button
            class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
          >
            2020 - 2021
          </button>
          <button
            class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
          >
            2016 - 2020
          </button>
        </div>
      </div>

      <!-- Right Column - Hobbies and Job Roles -->
      <div class="flex flex-col gap-8">
        <!-- Hobbies -->
        <div>
          <div class="flex flex-wrap gap-3 mb-6">
            <button
              class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
            >
              I play games
            </button>
            <button
              class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
            >
              Motorcycle rides
            </button>
            <button
              class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
            >
              I learn piano
            </button>
            <button
              class="px-4 py-2 rounded-lg border-2 border-brand-dark text-brand-dark font-medium text-sm hover:opacity-80 transition-opacity"
            >
              Watching anime
            </button>
          </div>
        </div>

        <!-- Job Roles -->
        <div class="space-y-4">
          <div>
            <div class="text-brand-dark font-bold text-sm md:text-base">
              Full-stack Developer
            </div>
            <div class="text-brand-dark text-sm md:text-base mt-1">
              Bapplware Technologies, Inc
            </div>
          </div>
          <div>
            <div class="text-brand-dark font-bold text-sm md:text-base">
              Full-stack Developer
            </div>
            <div class="text-brand-dark text-sm md:text-base mt-1">
              GEER IT Solutions
            </div>
          </div>
          <div>
            <div class="text-brand-dark font-bold text-sm md:text-base">
              Web Developer
            </div>
            <div class="text-brand-dark text-sm md:text-base mt-1">
              My Solid Technologies & Devices Corp.
            </div>
          </div>
          <div>
            <div class="text-brand-dark font-bold text-sm md:text-base">
              Web Developer
            </div>
            <div class="text-brand-dark text-sm md:text-base mt-1">
              Digima Web Solutions
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
