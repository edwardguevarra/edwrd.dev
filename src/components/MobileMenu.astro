---
import FilledButton from "./buttons/FilledButton.astro";
import NavLink from "./NavLink.astro";
import type { MobileMenuProps } from "../types/header.types";

const { navItems, isBlogPage } = Astro.props as MobileMenuProps;
---

<!-- Mobile Menu Backdrop -->
<div
  id="mobile-menu-backdrop"
  class="mobile-menu-backdrop fixed inset-0 z-[60] hidden bg-black/50 lg:hidden"
  aria-hidden="true"
  role="presentation"
  data-testid="mobile-menu-backdrop"
>
</div>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="mobile-menu relative z-[70] mt-6 hidden border-t border-white/10 pb-4 lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
  aria-hidden="true"
  tabindex="-1"
>
  <nav aria-label="Mobile navigation links">
    <div class="flex flex-col gap-4 pt-4">
      {
        navItems.map((item) => (
          <NavLink
            href={item.href}
            label={item.label}
            section={item.section}
            isActive={item.section === "blog" && isBlogPage}
            isMobile={true}
          />
        ))
      }
      <div id="mobile-menu-button-wrapper">
        <FilledButton href="/#contact" text="Let's Talk" color="white" />
      </div>
    </div>
  </nav>
</div>
