---
import { Image } from "astro:assets";
import heroImage from "../assets/hero.png";
import bgCircle from "../assets/bg-circle.png";
import Button from "./Button.astro";
---

<section
  class="bg-brand-dark relative flex-1 flex flex-col items-center justify-center py-4 md:py-8"
>
  <!-- Hero Image - Immediately discoverable for LCP optimization -->
  <div
    class="w-[200px] h-[350px] -bottom-20 z-50 contain-layout md:absolute md:w-[200px] md:h-[350px] md:-bottom-20"
  >
    <Image
      src={heroImage}
      alt="Hero"
      width={200}
      height={350}
      priority
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class="w-full h-full object-cover aspect-200/350"
    />
  </div>

  <!-- Circle Background -->
  <Image
    class="absolute left-0 right-0 bottom-0 m-auto z-0"
    src={bgCircle}
    alt="BG Circle"
    width={573}
    height={642}
  />

  <!-- Decorative arcs in bottom-right corner -->
  <div class="absolute bottom-0 right-0 w-96 h-96 opacity-20">
    <div
      class="absolute bottom-0 right-0 w-64 h-64 border-2 rounded-full border-brand-dark"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-80 h-80 border-2 rounded-full -translate-x-8 -translate-y-8 border-brand-dark"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-96 h-96 border-2 rounded-full -translate-x-16 -translate-y-16 border-brand-dark"
    >
    </div>
  </div>

  <!-- Centered Title -->
  <div class="text-center mb-8 md:mb-6 z-10">
    <h1
      data-animate
      class="text-brand-accent font-black text-8xl leading-16 tracking-normal mb-1"
    >
      edwrd
    </h1>
    <h2
      data-animate
      class="text-brand-accent font-black text-8xl leading-16 tracking-normal mb-1 animate-delay-100"
    >
      dev
    </h2>
    <h3
      data-animate
      class="text-brand-accent font-black text-8xl leading-16 tracking-normal animate-delay-200"
    >
      edwrd
    </h3>
  </div>

  <!-- Content Grid -->
  <div class="container z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <!-- Right Content Block - Statistics (shown first on mobile) -->
      <div
        class="flex flex-col justify-end items-center md:items-end space-y-3 md:space-y-4 md:order-last order-first text-center md:text-right"
      >
        <div data-animate class="text-center md:text-right animate-delay-300">
          <div
            class="text-white text-2xl font-semibold leading-8 tracking-normal"
          >
            10+
          </div>
          <div
            class="text-white text-sm font-normal leading-5 tracking-normal mt-1"
          >
            years of experience
          </div>
        </div>
        <div data-animate class="text-center md:text-right animate-delay-400">
          <div
            class="text-white text-2xl font-semibold leading-8 tracking-normal"
          >
            20+
          </div>
          <div
            class="text-white text-sm font-normal leading-5 tracking-normal mt-1"
          >
            projects completed
          </div>
        </div>
        <div data-animate class="text-center md:text-right animate-delay-500">
          <div
            class="text-white text-2xl font-semibold leading-8 tracking-normal"
          >
            9999+
          </div>
          <div
            class="text-white text-sm font-normal leading-5 tracking-normal mt-1"
          >
            errors debugged
          </div>
        </div>
      </div>

      <!-- Left Content Block (shown second on mobile) -->
      <div
        class="flex flex-col justify-end space-y-6 md:order-first order-last text-center md:text-left"
      >
        <p
          data-animate
          class="text-white text-sm font-normal leading-5 tracking-normal max-w-[240px] lg:max-w-[352px] animate-delay-300 mx-auto md:mx-0"
        >
          Experienced senior dev who always wants to learn and build stuffs. Got
          a project in mind? Send me a message!
        </p>
        <div
          data-animate
          class="animate-delay-400 flex justify-center md:justify-start"
        >
          <Button text="Let's Talk" variant="lime" filled={true} />
        </div>
      </div>
    </div>
  </div>
</section>
