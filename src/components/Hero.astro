---
import { Image } from "astro:assets";
import heroImage from "../assets/hero.png";
import bgCircle from "../assets/bg-circle.png";
import Button from "./Button.astro";
---

<section
  class="bg-brand-dark relative flex-1 flex flex-col items-center justify-center py-4 md:py-8"
>
  <!-- Hero Image - Immediately discoverable for LCP optimization -->
  <div class="absolute w-[200px] h-[350px] -bottom-20 z-50 contain-layout">
    <Image
      src={heroImage}
      alt="Hero"
      width={200}
      height={350}
      priority
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class="w-full h-full object-cover aspect-200/350"
    />
  </div>

  <!-- Circle Background -->
  <Image
    class="absolute left-0 right-0 bottom-0 m-auto z-0"
    src={bgCircle}
    alt="BG Circle"
    width={573}
    height={642}
  />

  <!-- Decorative arcs in bottom-right corner -->
  <div class="absolute bottom-0 right-0 w-96 h-96 opacity-20">
    <div
      class="absolute bottom-0 right-0 w-64 h-64 border-2 rounded-full border-brand-dark"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-80 h-80 border-2 rounded-full -translate-x-8 -translate-y-8 border-brand-dark"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-96 h-96 border-2 rounded-full -translate-x-16 -translate-y-16 border-brand-dark"
    >
    </div>
  </div>

  <!-- Centered Title -->
  <div class="text-center mb-4 md:mb-6 z-10">
    <h1
      class="text-brand-accent font-black text-8xl leading-16 tracking-normal mb-1"
    >
      edwrd
    </h1>
    <h2
      class="text-brand-accent font-black text-8xl leading-16 tracking-normal mb-1"
    >
      dev
    </h2>
    <h3
      class="text-brand-accent font-black text-8xl leading-16 tracking-normal"
    >
      edwrd
    </h3>
  </div>

  <!-- Content Grid -->
  <div class="container z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <!-- Left Content Block -->
      <div class="flex flex-col justify-end space-y-6">
        <p
          class="text-white text-sm font-normal leading-5 tracking-normal max-w-[240px] lg:max-w-[352px]"
        >
          Experienced senior dev who always wants to learn and build stuffs. Got
          a project in mind? Send me a message!
        </p>
        <Button text="Let's Talk" variant="lime" filled={true} />
      </div>

      <!-- Right Content Block - Statistics -->
      <div class="flex flex-col justify-end items-end space-y-3 md:space-y-4">
        <div class="text-right">
          <div
            class="text-white text-2xl font-semibold leading-8 tracking-normal"
          >
            10+
          </div>
          <div
            class="text-white text-sm font-normal leading-5 tracking-normal mt-1"
          >
            years of experience
          </div>
        </div>
        <div class="text-right">
          <div
            class="text-white text-2xl font-semibold leading-8 tracking-normal"
          >
            20+
          </div>
          <div
            class="text-white text-sm font-normal leading-5 tracking-normal mt-1"
          >
            projects completed
          </div>
        </div>
        <div class="text-right">
          <div
            class="text-white text-2xl font-semibold leading-8 tracking-normal"
          >
            9999+
          </div>
          <div
            class="text-white text-sm font-normal leading-5 tracking-normal mt-1"
          >
            errors debugged
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
