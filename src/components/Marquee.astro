---
export interface Props {
  text?: string;
  repeatCount?: number;
  animationDuration?: number;
}

const {
  text = 'print("Hello World") | console.log("Hello World"); | echo "Hello World"; | System.out.println("Hello World"); | printf("Hello World\\n"); | cout << "Hello World" << endl;',
  repeatCount = 4,
  animationDuration = 20,
} = Astro.props;
---

<div class="marquee-container overflow-hidden mb-8">
  <div
    class="marquee-content flex gap-8"
    style={`animation-duration: ${animationDuration}s`}
  >
    <span class="marquee-text text-brand-dark whitespace-nowrap">
      {text}
    </span>
    {
      Array.from({ length: repeatCount - 1 }, (_, i) => (
        <span
          class="marquee-text text-brand-dark whitespace-nowrap"
          aria-hidden="true"
        >
          {text}
        </span>
      ))
    }
  </div>
</div>

<style>
  .marquee-container {
    width: 100%;
  }

  .marquee-content {
    animation: marquee var(--animation-duration, 20s) linear infinite;
    display: flex;
    width: max-content;
  }

  .marquee-text {
    font-family: "Fira Code", monospace;
    font-weight: 600;
    font-size: 14px;
    line-height: 22px;
    letter-spacing: 0%;
    text-align: right;
    padding-right: 2rem;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .marquee-content:hover {
    animation-play-state: paused;
  }

  /* Responsive adjustments for different screen sizes */
  @media (min-width: 768px) {
    .marquee-content {
      animation-duration: calc(var(--animation-duration, 20s) + 5s);
    }
  }

  @media (min-width: 1024px) {
    .marquee-content {
      animation-duration: calc(var(--animation-duration, 20s) + 10s);
    }
  }

  @media (min-width: 1280px) {
    .marquee-content {
      animation-duration: calc(var(--animation-duration, 20s) + 15s);
    }
  }
</style>
