---
import Button from "./Button.astro";
import { Image } from "astro:assets";
import bgCircle from "../assets/bg-circle.png";
---

<footer class="bg-brand-dark border-t border-white/10 mt-auto">
  <div class="container relative">
    <!-- Circle Background -->
    <Image
      src={bgCircle}
      alt="BG Circle"
      width={573}
      height={642}
      class="absolute left-0 right-0 bottom-0 m-auto z-0"
    />

    <!-- Branding -->
    <div class="text-center text-brand-accent font-black text-8xl py-16">
      edwrd.dev
    </div>

    <!-- Footer Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 items-center gap-8 pb-10 pt-40">
      <!-- Logo -->
      <div
        class="text-brand-lime font-bold text-xl text-center lg:text-left relative z-10"
      >
        edwrd
      </div>

      <!-- Navigation Links -->
      <nav
        class="flex items-center justify-center gap-4 lg:gap-[100px] relative z-10"
      >
        <a
          href="#about"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >About</a
        >
        <a
          href="#projects"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >Works</a
        >
        <a
          href="#contact"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >Contact</a
        >
        <a
          href="#blog"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >Blog</a
        >
      </nav>

      <!-- CTA Button -->
      <div class="flex justify-center lg:justify-end">
        <Button
          text="Let's Talk"
          variant="white"
          filled={true}
          position="right"
        />
      </div>
    </div>
  </div>
</footer>
