---
import Button from "./Button.astro";
---

<footer class="bg-brand-dark border-t border-white/10 mt-auto">
  <div class="container">
    <!-- Branding -->
    <div class="text-center text-brand-accent font-black text-8xl py-16">
      edwrd.dev
    </div>

    <!-- Footer Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 items-center gap-8 pb-16 pt-40">
      <!-- Logo -->
      <div class="text-brand-lime font-bold text-xl text-center lg:text-left">
        edwrd
      </div>

      <!-- Navigation Links -->
      <nav class="flex items-center justify-center gap-4 lg:gap-[100px]">
        <a
          href="#about"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >About</a
        >
        <a
          href="#works"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >Works</a
        >
        <a
          href="#contact"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >Contact</a
        >
        <a
          href="#blog"
          class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
          >Blog</a
        >
      </nav>

      <!-- CTA Button -->
      <div class="flex justify-center lg:justify-end">
        <Button
          text="Let's Talk"
          variant="white"
          filled={true}
          position="right"
        />
      </div>
    </div>
  </div>
</footer>
