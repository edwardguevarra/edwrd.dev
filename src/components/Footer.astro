---
import Button from "./Button.astro";
import { Image } from "astro:assets";
import bgCircle from "../assets/bg-circle.png";
import { getNavigationItems } from "../config/navigation";

// Footer links should work from any page, so use full paths
const navItems = getNavigationItems(false);
---

<footer class="bg-brand-dark border-t border-white/10 mt-auto">
  <div class="container relative">
    <!-- Circle Background -->
    <Image
      src={bgCircle}
      alt="BG Circle"
      width={573}
      height={642}
      class="absolute left-0 right-0 bottom-0 m-auto z-0"
    />

    <!-- Branding -->
    <div
      class="text-center text-brand-accent font-black text-8xl py-16 hidden md:block"
    >
      edwrd.dev
    </div>

    <!-- Footer Content -->
    <div
      class="flex flex-wrap justify-between items-center gap-8 pb-10 pt-20 lg:pt-40 flex-col lg:flex-row"
    >
      <!-- Logo -->
      <div
        class="text-brand-lime font-bold text-xl text-center lg:text-left relative z-10"
      >
        edwrd
      </div>

      <!-- Navigation Links -->
      <nav
        class="flex items-center justify-center gap-4 lg:gap-[100px] relative z-10"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-white hover:opacity-80 transition-opacity font-semibold text-sm leading-[22px] tracking-normal text-center cursor-pointer"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- CTA Button -->
      <div class="flex justify-center lg:justify-end relative z-10">
        <Button
          text="Let's Talk"
          variant="white"
          filled={true}
          class="ml-auto"
        />
      </div>
    </div>
  </div>
</footer>
