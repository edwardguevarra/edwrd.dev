---
import { Image } from "astro:assets";
import toolsImage from "../../public/images/tools.png";
import OutlineButton from "./buttons/OutlineButton.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const projects = await getCollection("projects");
type ProjectEntry = CollectionEntry<"projects">;
---

<section id="projects" class="bg-brand-accent pt-6 pb-20">
  <div class="container mx-auto px-4">
    <div class="flex flex-col items-center justify-between md:flex-row">
      <!-- Left column for Skill/Tools button and additional content -->
      <div class="mb-4 w-full md:mb-0 md:w-1/2">
        <div data-animate>
          <OutlineButton text="Skill / Tools" />
        </div>
        <div data-animate class="animate-delay-200 mt-8">
          <Image
            src={toolsImage}
            alt="Tools"
            width={500}
            height={500}
            class="w-full max-w-md"
          />
        </div>
      </div>

      <!-- Right column for title -->
      <div class="w-full pt-8 text-center md:w-1/2 md:pt-0 md:text-right">
        <h2
          data-animate
          class="font-inter text-brand-dark animate-delay-100 text-4xl leading-tight font-black tracking-normal md:text-5xl md:leading-snug lg:text-6xl lg:leading-[72px]"
        >
          My Projects/<br />Works
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-1 gap-6 py-6 md:grid-cols-3">
      {
        projects.map((project: ProjectEntry, index: number) => {
          const delayClasses = [
            "",
            "animate-delay-100",
            "animate-delay-200",
            "animate-delay-300",
            "animate-delay-400",
            "animate-delay-500",
          ];
          return (
            <a
              data-animate
              href={project.data.link}
              class={`group block ${delayClasses[index] || ""}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <article class="flex h-full flex-col overflow-hidden rounded-lg bg-white shadow-[6px_6px_6px_0px_rgba(0,0,0,0.25)] transition-all duration-300 hover:shadow-[8px_8px_8px_0px_rgba(0,0,0,0.3)]">
                <div class="relative overflow-hidden">
                  <Image
                    src={project.data.image}
                    alt={project.data.alt}
                    width={425}
                    height={300}
                    loading="lazy"
                    class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
                <div class="flex grow flex-col p-6">
                  <h3 class="font-inter text-brand-dark group-hover:text-brand-dark/80 mb-2 text-xl font-bold transition-colors">
                    {project.data.title}
                  </h3>
                  {project.data.description && (
                    <p class="text-brand-dark/70 line-clamp-3 text-sm">
                      {project.data.description}
                    </p>
                  )}
                </div>
              </article>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
