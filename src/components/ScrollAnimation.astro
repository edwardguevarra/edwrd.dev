<script>
  document.addEventListener("DOMContentLoaded", () => {
    import("../services/scroll-animation/index.js")
      .then(({ createScrollAnimationService }) => {
        // Query animated elements
        const animatedElements =
          document.querySelectorAll<HTMLElement>("[data-animate]");

        // Initialize scroll animation service
        const scrollAnimationService = createScrollAnimationService({
          elements: { animatedElements },
        });
        scrollAnimationService.initialize();

        // Cleanup on page unload
        window.addEventListener("beforeunload", () => {
          scrollAnimationService.destroy();
        });
      })
      .catch((error) => {
        console.warn(
          "[ScrollAnimation] Failed to load scroll animation service:",
          {
            error: error instanceof Error ? error.message : String(error),
            stack: error instanceof Error ? error.stack : undefined,
          }
        );
      });
  });
</script>
