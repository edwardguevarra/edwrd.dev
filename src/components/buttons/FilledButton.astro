---
import { Icon } from "astro-icon/components";

export interface Props {
  text: string;
  href?: string;
  icon?: string;
  class?: string;
  color: "white" | "lime";
  target?: string;
}

const { text, class: className = "", href, icon, color, target } = Astro.props;

const baseClasses =
  "w-fit px-[54px] py-[9px] rounded-[50px] border font-semibold text-[14px] leading-[22px] tracking-normal text-center hover:opacity-80 transition-opacity flex items-center justify-center gap-2 cursor-pointer";

const colorClasses =
  color === "white"
    ? "bg-white text-brand-dark border-white"
    : "bg-brand-lime text-brand-dark border-brand-lime";
---

{
  href ? (
    <a
      href={href}
      {...(target && { target })}
      {...(target === "_blank" && { rel: "noopener noreferrer" })}
      class={`${baseClasses} ${colorClasses} ${className}`}
      data-testid="filled-button"
    >
      {text}
      {icon && <Icon name={icon} width="16" height="16" />}
    </a>
  ) : (
    <button
      class={`${baseClasses} ${colorClasses} ${className}`}
      data-testid="filled-button"
    >
      {text}
      {icon && <Icon name={icon} width="16" height="16" />}
    </button>
  )
}
