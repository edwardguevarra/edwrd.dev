---
import { Icon } from "astro-icon/components";

export interface Props {
  text: string;
  href?: string;
  icon?: string;
  class?: string;
  color?: "dark" | "white";
  target?: string;
  "data-testid"?: string;
}

const {
  text,
  class: className = "",
  href,
  icon,
  color = "dark",
  target,
  "data-testid": dataTestId = "outline-button",
} = Astro.props as Props;

const baseClasses =
  "w-fit max-w-full px-8 py-[9px] rounded-[50px] border font-semibold text-[14px] leading-[22px] tracking-normal text-center hover:opacity-80 transition-opacity flex items-center justify-center gap-2 cursor-pointer sm:px-[54px]";

const colorClasses =
  color === "white"
    ? "border-white text-white"
    : "border-brand-dark text-brand-dark";
---

{
  href ? (
    <a
      href={href}
      {...(target && { target })}
      {...(target === "_blank" && { rel: "noopener noreferrer" })}
      class={`${baseClasses} ${colorClasses} ${className}`}
      data-testid={dataTestId}
    >
      {text}
      {icon && <Icon name={icon} width="16" height="16" />}
    </a>
  ) : (
    <button
      class={`${baseClasses} ${colorClasses} ${className}`}
      data-testid={dataTestId}
    >
      {text}
      {icon && <Icon name={icon} width="16" height="16" />}
    </button>
  )
}
